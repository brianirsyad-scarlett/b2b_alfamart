name: Monthly Report (1 AM WIB on 1st day)

on:
  schedule:
    - cron: '0 18 1 * *'   # 18:00 UTC on day 1 = 01:00 WIB on day 2
  workflow_dispatch:

jobs:
  run-monthly:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Install dependencies
        run: pip install selenium webdriver-manager pyotp

      - name: Run monthly report script
        run: python report_monthly.py
        env:
          TOTP_SECRET: ${{ secrets.TOTP_SECRET }}

      - name: Upload downloaded files
        uses: actions/upload-artifact@v4
        with:
          name: monthly-report
          path: /tmp/downloads/
          retention-days: 30
